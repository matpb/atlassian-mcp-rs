# MCP HTTP server bind (optional)
# MCP_HOST=0.0.0.0
MCP_PORT=8432

# Optional tracing
# RUST_LOG=atlassian_mcp=debug,rmcp=warn

# --- Atlassian credentials are NOT read by this server ---
# Configure them in your MCP client (HTTP headers on each request), e.g. in .mcp.json:
#   X-Atlassian-Site-Url, X-Atlassian-Email, X-Atlassian-Api-Token
# You can still keep ATLASSIAN_* in a local .env for Claude/env expansion only.
